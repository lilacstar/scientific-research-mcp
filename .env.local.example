# ============================================
# Scientific Research MCP - 个人配置模板
# ============================================
# 使用方法：
# 1. 复制此文件为 .env.local
#    cp .env.local.example .env.local
# 2. 填写你的实际配置值
# 3. .env.local 已被 .gitignore 排除，不会被提交到GitHub

# ============================================
# LLM API 配置
# ============================================
# 支持任何兼容 OpenAI API 格式的大模型
# 包括：阿里云 DashScope、OpenAI、DeepSeek、智谱、Ollama 等

# API 端点地址（OpenAI 兼容格式）
# 常用示例：
#   阿里云: https://dashscope.aliyuncs.com/compatible-mode/v1
#   OpenAI: https://api.openai.com/v1
#   DeepSeek: https://api.deepseek.com/v1
#   智谱: https://open.bigmodel.cn/api/paas/v4
#   Ollama本地: http://localhost:11434/v1
LLM_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# API Key（必填）
LLM_API_KEY=your-api-key-here

# 模型名称
# 常用模型：
#   阿里云: qwen-plus, qwen-turbo, qwen-max
#   OpenAI: gpt-4, gpt-3.5-turbo
#   DeepSeek: deepseek-chat
#   智谱: glm-4
#   Ollama: llama3, mistral
LLM_MODEL=qwen-plus

# ============================================
# GitHub 配置（可选，仅用于脚本上传文件）
# ============================================

# GitHub Personal Access Token
# 获取方式：https://github.com/settings/tokens
# 需要勾选 repo 权限
GITHUB_TOKEN=your-github-token-here

# GitHub 用户名
GITHUB_OWNER=your-username

# GitHub 仓库名
GITHUB_REPO=scientific-research-mcp

# ============================================
# 企业微信通知（可选）
# ============================================

# 企业微信群机器人 Webhook URL
# 用于接收任务完成通知、进度提醒等
WECHAT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your-key-here