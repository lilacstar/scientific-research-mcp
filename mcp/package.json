{
  "name": "scientific-research-mcp",
  "version": "1.0.0",
  "description": "Scientific Research MCP Server - AI-powered academic paper writing assistant",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "scientific-research-mcp": "./src/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node build/index.js",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js"
  },
  "keywords": [
    "mcp",
    "scientific-research",
    "paper-writing",
    "academic"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {},
    "moduleNameMapper": {
      "^(\\.\\.?/.*)\\.js$": "$1"
    }
  }
}