# Scientific Research MCP Server 环境变量配置

# ==================== LLM API ====================
# 阿里云 DashScope API Key（必需）
# 用于论文写作、润色、验证等功能
ALIBABA_CLOUD_API_KEY=sk-your-api-key-here

# ==================== 文献检索 API ====================
# OpenAlex API（已集成，无需 Key）
# 用于英文文献检索和引用验证
# 完全免费，无需配置

# CNKI API（可选，待扩展）
# 用于中文文献检索
# CNKI_API_KEY=your-cnki-api-key-here

# 万方数据 API（可选，待扩展）
# 用于中文文献检索
# WANFANG_API_KEY=your-wanfang-api-key-here

# ==================== 通知配置 ====================
# 企业微信 Webhook（可选）
# 用于接收写作进度通知
# WECHAT_WEBHOOK=https://qyapi.weixin.qq.com/cgi/webhook/send?key=your-key

# ==================== 路径配置 ====================
# 论文工作区路径（可选，默认为 ./paper）
# PAPER_DIR=/path/to/your/paper/workspace